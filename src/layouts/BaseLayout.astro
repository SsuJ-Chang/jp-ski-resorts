---
import '../styles/global.css'
import { withBasePath } from '../utils/paths'

type Props = {
  title: string
  description?: string
  bodyClass?: string
}

const {
  title,
  description = '給台灣滑雪者使用的日本滑雪場靜態資料與行程規劃入口。',
  bodyClass,
} = Astro.props
const currentYear = new Date().getFullYear()
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <a class="site-header__brand" href={withBasePath('/')}>日本滑雪場指南</a>
      <nav class="site-header__nav" aria-label="Primary navigation">
        <a href={withBasePath('/')}>首頁</a>
        <a href={withBasePath('/resorts/')}>滑雪場</a>
        <a href={withBasePath('/ski-areas/')}>雪場區域</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">© {currentYear} RJ. All rights reserved.</footer>
  </body>
</html>
