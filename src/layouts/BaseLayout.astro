---
import '../styles/global.css'
import { withBasePath } from '../utils/paths'

type Props = {
  title: string
  description?: string
}

const {
  title,
  description = '給台灣滑雪者使用的日本滑雪場靜態資料與行程規劃入口。',
} = Astro.props
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
    <title>{title}</title>
  </head>
  <body>
    <img
      class="page-background"
      src={withBasePath('/images/mountain-lines.svg')}
      alt=""
      aria-hidden="true"
    />
    <header class="site-header">
      <a class="site-header__brand" href={withBasePath('/')}>JP Ski Resorts</a>
      <nav class="site-header__nav" aria-label="Primary navigation">
        <a href={withBasePath('/')}>首頁</a>
        <a href={withBasePath('/resorts/')}>滑雪場</a>
      </nav>
    </header>
    <slot />
  </body>
</html>
