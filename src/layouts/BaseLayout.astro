---
import '../styles/global.css'
import BackToTopButton from '../components/BackToTopButton.astro'
import HeaderSearch from '../components/HeaderSearch.astro'
import GoogleAnalytics from '../components/GoogleAnalytics.astro'
import { withBasePath } from '../utils/paths'

type Props = {
  title: string
  description?: string
  bodyClass?: string
  showHeaderSearch?: boolean
}

const {
  title,
  description = '給台灣滑雪者使用的日本滑雪場靜態資料與行程規劃入口。',
  bodyClass,
  showHeaderSearch = false,
} = Astro.props
const currentYear = new Date().getFullYear()
const resortListPath = withBasePath('/resorts/')
const authorHomeUrl = 'https://rj-tw.com/'
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
    <title>{title}</title>
    <GoogleAnalytics />
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <a class="site-header__brand" href={withBasePath('/')}>日本滑雪場指南</a>
      <div class="site-header__actions">
        <nav class="site-header__nav" aria-label="Primary navigation">
          <a href={withBasePath('/')}>首頁</a>
          <a href={resortListPath}>滑雪場</a>
          <a href={withBasePath('/ski-areas/')}>雪場區域</a>
        </nav>
        {showHeaderSearch && <HeaderSearch resortsUrl={resortListPath} />}
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="site-footer__copyright">
          © {currentYear} RJ. All rights reserved.
          <span class="site-footer__divider" aria-hidden="true">・</span>
          <a
            class="site-footer__contact"
            href={authorHomeUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="前往 RJ 個人首頁聯絡作者，新分頁開啟"
          >
            聯絡作者 <span class="site-footer__contact-url">rj-tw.com</span>
          </a>
        </p>
      </div>
    </footer>
    <BackToTopButton />
  </body>
</html>
