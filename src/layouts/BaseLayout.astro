---
import '../styles/global.css'

type Props = {
  title: string
  description?: string
}

const {
  title,
  description = '給台灣滑雪者使用的日本滑雪場靜態資料與行程規劃入口。',
} = Astro.props
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <img
      class="page-background"
      src={`${import.meta.env.BASE_URL}images/mountain-lines.svg`}
      alt=""
      aria-hidden="true"
    />
    <slot />
  </body>
</html>
