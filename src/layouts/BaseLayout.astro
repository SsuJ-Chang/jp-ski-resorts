---
import '../styles/global.css'
import BackToTopButton from '../components/BackToTopButton.astro'
import HeaderSearch from '../components/HeaderSearch.astro'
import GoogleAnalytics from '../components/GoogleAnalytics.astro'
import { withBasePath } from '../utils/paths'

type Props = {
  title: string
  description?: string
  bodyClass?: string
  showHeaderSearch?: boolean
  canonicalPath?: string
  ogType?: 'website' | 'article'
  noindex?: boolean
  structuredData?: Record<string, unknown> | Record<string, unknown>[]
}

const {
  title,
  description = '給台灣滑雪者使用的日本滑雪場靜態資料與行程規劃入口。',
  bodyClass,
  showHeaderSearch = false,
  canonicalPath,
  ogType = 'website',
  noindex = false,
  structuredData,
} = Astro.props
const currentYear = new Date().getFullYear()
const resortListPath = withBasePath('/resorts/')
const contactPath = withBasePath('/contact/')
const aboutPath = withBasePath('/about/')
const siteUrl = Astro.site ?? new URL('https://jp-resorts.rj-tw.com')
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, siteUrl).toString()
const siteName = '日本滑雪場指南'
const socialImageUrl = new URL(withBasePath('/images/og-image.png'), siteUrl).toString()
const socialImageAlt = '日本滑雪場指南'
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />
    <meta name="author" content="RJ" />
    <meta name="theme-color" content="#f7f8f3" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={withBasePath('/favicon.ico')} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={withBasePath('/favicon-32x32.png')} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBasePath('/favicon-16x16.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBasePath('/apple-touch-icon.png')} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1731" />
    <meta property="og:image:height" content="909" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    {structuredData && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    )}
    <GoogleAnalytics />
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <a class="site-header__brand" href={withBasePath('/')}>
        <img
          class="site-header__brand-icon"
          src={withBasePath('/favicon-32x32.png')}
          alt=""
          width="32"
          height="32"
          aria-hidden="true"
        />
        <span>日本滑雪場指南</span>
      </a>
      <div class="site-header__actions">
        <nav class="site-header__nav" aria-label="Primary navigation">
          <a href={withBasePath('/')}>首頁</a>
          <a href={resortListPath}>滑雪場</a>
          <a href={withBasePath('/ski-areas/')}>雪場區域</a>
        </nav>
        {showHeaderSearch && <HeaderSearch resortsUrl={resortListPath} />}
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="site-footer__copyright">
          © {currentYear} RJ. All rights reserved.
          <span class="site-footer__divider" aria-hidden="true">・</span>
          <a class="site-footer__link" href={withBasePath('/privacy/')}>隱私權政策</a>
          <span class="site-footer__divider" aria-hidden="true">・</span>
          <a class="site-footer__link" href={withBasePath('/thanks/')}>特別感謝</a>
          <span class="site-footer__divider" aria-hidden="true">・</span>
          <a class="site-footer__link" href={aboutPath}>關於本站</a>
          <span class="site-footer__divider" aria-hidden="true">・</span>
          <a
            class="site-footer__contact"
            href={contactPath}
            aria-label="前往聯絡作者頁面"
          >
            聯絡作者
          </a>
        </p>
      </div>
    </footer>
    <BackToTopButton />
    <script>
      import '../scripts/deferredEnhancements.ts'
    </script>
  </body>
</html>
