---
import BaseLayout from '../layouts/BaseLayout.astro'
import { withBasePath } from '../utils/paths'

const aboutCards = [
  {
    eyebrow: '網站內容',
    title: '滑雪場資料整理',
    description:
      '用繁體中文整理雪場基本資訊、官方入口、票價參考、交通與區域分類，讓查找流程更直接。',
  },
  {
    eyebrow: '網站內容',
    title: '雪道與滑行判讀',
    description:
      '把雪道數量、難度分布、代表路線與滑行印象整理成比較容易理解的形式，協助快速比對雪場差異。',
  },
  {
    eyebrow: '網站內容',
    title: '外部參考入口',
    description:
      '補充官方網站、雪道地圖、雪況天氣，以及公開 blog／vlog 連結，方便繼續往下做更細的規劃。',
  },
  {
    eyebrow: '整理原則',
    title: '以公開來源為主',
    description:
      '站內資訊以雪場官方網站、公開地圖、公開遊記與影片等可查證來源為基礎，不使用封閉資料或即時抓取服務。',
  },
  {
    eyebrow: '整理原則',
    title: '整理與彙整，不是官方公告',
    description:
      '這個網站的角色是整理者，不是雪場官方。站內內容會盡量交叉比對，但仍應以雪場最新公告作為最終依據。',
  },
  {
    eyebrow: '整理原則',
    title: '持續更新，但可能有時間差',
    description:
      '票價、營運期間、交通方式與雪道資訊都可能調整；如果官方更新速度快，站內資料可能會有短暫落差。',
  },
  {
    eyebrow: '使用提醒',
    title: '不保證所有資訊都是即時最新',
    description:
      '像票價、營運期間、交通接駁與雪況這類資訊，可能在雪季中快速調整；就像店家臨時改營業時間，最終仍應以官方公告為準。',
  },
  {
    eyebrow: '使用提醒',
    title: '本站不提供訂票、訂房或即時查詢',
    description:
      '這裡比較像整理好的索引與導覽頁，而不是滑雪版的訂房平台；重點是幫你更快找到方向，再前往官方或外部來源做最後確認。',
  },
  {
    eyebrow: '使用提醒',
    title: '部分內容是整理後的判讀',
    description:
      '例如雪道特性、滑行感受或適合對象，會盡量基於公開資料整理，但仍帶有彙整與解讀成分，不是唯一標準答案。',
  },
  {
    eyebrow: '聯絡修正',
    title: '資料修正與補充來源',
    description:
      '如果你發現資料需要修正、想補充公開來源，或希望進一步了解本站如何處理資料，可前往',
    href: withBasePath('/contact/'),
    linkText: '聯絡作者',
    descriptionSuffix: '頁；隱私與分析相關說明則可參考',
    secondaryHref: withBasePath('/privacy/'),
    secondaryLinkText: '隱私權政策',
    secondarySuffix: '。',
  },
]

const aboutStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: '關於本站｜日本滑雪場指南',
  description: '說明日本滑雪場指南的網站定位、資料整理方式、更新原則與聯絡修正方式。',
  inLanguage: 'zh-Hant-TW',
  url: 'https://jp-resorts.rj-tw.com/about/',
}
---

<BaseLayout
  title="關於本站｜日本滑雪場指南"
  description="說明日本滑雪場指南的網站定位、資料整理方式、更新原則與聯絡修正方式。"
  bodyClass="about-page"
  canonicalPath="/about/"
  structuredData={aboutStructuredData}
>
  <main class="site-shell page-stack about-shell">
    <section class="page-heading about-hero" aria-labelledby="about-title">
      <p class="eyebrow">About</p>
      <h1 id="about-title">關於本站</h1>
      <p>
        作者 RJ 是一位熱愛滑雪的台灣人，第一次到白馬栂池高原滑雪就深深愛上滑雪，決定每年都至少去一趟，但每年準備行程前的整理資料過程非常繁複。
        常常會在各網站間跳來跳去，需要花費大量時間比對雪場資訊、票價與交通方式，才整理出想要的結果。
      </p>
      <p>
        這個網站就是希望把這些資訊整理成更容易理解的形式，並且集中在同一個地方，讓滑雪愛好者可以更快找到想要的資訊，並且有更多外部參考來源可以延伸參考。
      </p>
    </section>

    <section class="footer-page-section" aria-label="關於本站內容">
      <ol class="footer-page-list">
        {aboutCards.map((card, index) => (
          <li class="footer-page-card" style={`--index: ${index}`}>
            <div class="footer-page-card__meta">
              <p class="footer-page-card__eyebrow">{card.eyebrow}</p>
            </div>
            <div class="footer-page-card__content">
              <h2 class="footer-page-card__title">{card.title}</h2>
              <p class="footer-page-card__description">
                {card.description}
                {card.href && card.linkText && (
                  <>
                    <a class="text-link" href={card.href}> {card.linkText} </a>
                    {card.descriptionSuffix}
                    <a class="text-link" href={card.secondaryHref}> {card.secondaryLinkText} </a>
                    {card.secondarySuffix}
                  </>
                )}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </main>
</BaseLayout>
