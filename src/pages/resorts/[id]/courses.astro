---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { tagLabels } from '../../../data/tags'
import { filterPublishedResorts } from '../../../utils/resorts'
import { withBasePath } from '../../../utils/paths'

const difficultyLabels = {
  beginner: '初級',
  intermediate: '中級',
  advanced: '上級',
  expert: '專家',
  ungroomed: '非壓雪',
  mixed: '混合',
} as const

export async function getStaticPaths() {
  const resorts = filterPublishedResorts(await getCollection('resorts')).filter(
    (resort) => resort.data.courses?.courseInfoPage,
  )

  return resorts.map((resort) => ({
    params: { id: resort.id },
    props: { resort },
  }))
}

const { resort } = Astro.props
const courseDetails = resort.data.courses?.details ?? []
const previewCourseCount = 3
const difficultyOrder = ['beginner', 'intermediate', 'advanced', 'expert', 'ungroomed', 'mixed'] as const
const courseGroups = difficultyOrder
  .map((difficulty) => {
    const courses = courseDetails.filter((course) => course.difficulty === difficulty)

    return {
      difficulty,
      label: difficultyLabels[difficulty],
      courses,
      previewCourses: courses.slice(0, previewCourseCount),
      collapsedCourses: courses.slice(previewCourseCount),
    }
  })
  .filter((group) => group.courses.length > 0)
---

<BaseLayout
  title={`${resort.data.name.zhTw}雪道資訊 | 日本滑雪場指南`}
  description={`${resort.data.name.zhTw} 的雪道資料、難度、坡度與影片連結。`}
>
  <main
    class="site-shell page-stack"
    data-analytics-view="resort_courses"
    data-resort-slug={resort.id}
    data-resort-region={resort.data.region}
    data-resort-prefecture={resort.data.prefecture}
    data-course-count={courseDetails.length}
    data-course-group-count={courseGroups.length}
  >
    <a class="text-link" href={withBasePath(`/resorts/${resort.id}/`)}>回雪場頁面</a>

    <section class="page-heading" aria-labelledby="page-title">
      <p class="eyebrow">Course guide</p>
      <h1 id="page-title">{resort.data.name.zhTw}</h1>
      <div class="tag-list">
        {resort.data.tags.map((tag) => (
          <span>{tagLabels[tag]}</span>
        ))}
      </div>
    </section>

    <section class="course-level-list" aria-label={`${resort.data.name.zhTw} courses`}>
      {
        courseGroups.length > 0 ? (
          courseGroups.map((group) => (
            <section class="course-level-section" aria-labelledby={`course-level-${group.difficulty}`}>
              <div class="course-level-header">
                <div>
                  <h2 id={`course-level-${group.difficulty}`} class={`course-level-title course-level-title--${group.difficulty}`}>
                    {group.label}
                  </h2>
                </div>
                {
                  group.collapsedCourses.length > 0 ? (
                    <button
                      class="course-level-toggle"
                      type="button"
                      data-course-toggle
                      data-resort-slug={resort.id}
                      data-resort-region={resort.data.region}
                      data-resort-prefecture={resort.data.prefecture}
                      data-course-difficulty={group.difficulty}
                      data-course-count={group.courses.length}
                      aria-expanded="false"
                      aria-controls={`course-extra-${resort.id}-${group.difficulty}`}
                    >
                      <span>{group.courses.length} 條雪道</span>
                    </button>
                  ) : (
                    <p class="course-level-count">{group.courses.length} 條雪道</p>
                  )
                }
              </div>

              <div class="course-list">
                {group.previewCourses.map((course) => (
                  <article class="course-card">
                    <div>
                      <h3>{course.name}</h3>
                      {course.note && <p>{course.note}</p>}
                    </div>
                    <dl class="course-facts">
                      {course.length && (
                        <div>
                          <dt>長度</dt>
                          <dd>{course.length}</dd>
                        </div>
                      )}
                      {course.maxSlope && (
                        <div>
                          <dt>最大坡度</dt>
                          <dd>{course.maxSlope}</dd>
                        </div>
                      )}
                      {course.averageSlope && (
                        <div>
                          <dt>平均坡度</dt>
                          <dd>{course.averageSlope}</dd>
                        </div>
                      )}
                    </dl>
                    {course.videoLinks && course.videoLinks.length > 0 && (
                      <ul class="course-video-links">
                        {course.videoLinks.map((videoUrl, videoIndex) => (
                          <li>
                            <a
                              href={videoUrl}
                              target="_blank"
                              rel="noreferrer noopener"
                              data-analytics-resource="course_video"
                              data-analytics-label={`${course.name} 參考影片${(course.videoLinks?.length ?? 0) > 1 ? videoIndex + 1 : ''}`}
                              data-analytics-note={course.note}
                            >
                              {(course.videoLinks?.length ?? 0) > 1 ? `參考影片${videoIndex + 1}` : '參考影片'}
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </article>
                ))}
              </div>

              {
                group.collapsedCourses.length > 0 && (
                  <div
                    id={`course-extra-${resort.id}-${group.difficulty}`}
                    class="course-list course-list--extra"
                    hidden
                  >
                    {group.collapsedCourses.map((course) => (
                      <article class="course-card">
                        <div>
                          <h3>{course.name}</h3>
                          {course.note && <p>{course.note}</p>}
                        </div>
                        <dl class="course-facts">
                          {course.length && (
                            <div>
                              <dt>長度</dt>
                              <dd>{course.length}</dd>
                            </div>
                          )}
                          {course.maxSlope && (
                            <div>
                              <dt>最大坡度</dt>
                              <dd>{course.maxSlope}</dd>
                            </div>
                          )}
                          {course.averageSlope && (
                            <div>
                              <dt>平均坡度</dt>
                              <dd>{course.averageSlope}</dd>
                            </div>
                          )}
                        </dl>
                        {course.videoLinks && course.videoLinks.length > 0 && (
                          <ul class="course-video-links">
                            {course.videoLinks.map((videoUrl, videoIndex) => (
                              <li>
                                <a
                                  href={videoUrl}
                                  target="_blank"
                                  rel="noreferrer noopener"
                                  data-analytics-resource="course_video"
                                  data-analytics-label={`${course.name} 參考影片${(course.videoLinks?.length ?? 0) > 1 ? videoIndex + 1 : ''}`}
                                  data-analytics-note={course.note}
                                >
                                  {(course.videoLinks?.length ?? 0) > 1 ? `參考影片${videoIndex + 1}` : '參考影片'}
                                </a>
                              </li>
                            ))}
                          </ul>
                        )}
                      </article>
                    ))}
                  </div>
                )
              }
            </section>
          ))
        ) : (
          <section class="empty-state">
            <h2>雪道資料整理中</h2>
            <p>
              這座雪場的雪道詳細資料尚未整理完成。完成後將提供雪道名稱、難度分級、坡度與可參考的滑行影片連結。
            </p>
          </section>
        )
      }
    </section>
  </main>

  <script>
    import { trackEvent } from '../../../scripts/analytics'

    document.querySelectorAll('[data-course-toggle]').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const controls = toggle.getAttribute('aria-controls')
        const target = controls ? document.getElementById(controls) : null

        if (!target) return

        const isExpanded = toggle.getAttribute('aria-expanded') === 'true'
        toggle.setAttribute('aria-expanded', String(!isExpanded))
        target.hidden = isExpanded

        if (!isExpanded && toggle instanceof HTMLElement) {
          trackEvent('course_group_expand', {
            resort_slug: toggle.dataset.resortSlug,
            resort_region: toggle.dataset.resortRegion,
            resort_prefecture: toggle.dataset.resortPrefecture,
            course_difficulty: toggle.dataset.courseDifficulty,
            course_count: Number(toggle.dataset.courseCount ?? 0),
          })
        }
      })
    })
  </script>
</BaseLayout>
