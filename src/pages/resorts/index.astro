---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ListingFilterNav from '../../components/ListingFilterNav.astro'
import ResortSearchResults from '../../components/ResortSearchResults.astro'
import { regions } from '../../data/regions'
import { getPrefectureStats, getTagStats } from '../../utils/resortBrowse'
import { sortResortsForListing } from '../../utils/resortOrdering'
import { filterPublishedResorts } from '../../utils/resorts'

const resorts = sortResortsForListing(filterPublishedResorts(await getCollection('resorts')))
const prefectureStats = getPrefectureStats(resorts)
const tagStats = getTagStats(resorts)

const regionNamesByKey = Object.fromEntries(
  regions.map((region) => [region.key, region.name.zhTw]),
)
---

<BaseLayout
  title="滑雪場列表 | 日本滑雪場指南"
  description="日本滑雪場靜態資料列表，整理區域、標籤與官方資訊入口。"
  showHeaderSearch
>
  <main class="site-shell page-stack">
    <section class="page-heading" aria-labelledby="page-title">
      <p class="eyebrow">Resort database</p>
      <h1 id="page-title">滑雪場列表</h1>
      <p>
        彙整各滑雪場的基本資訊、特色標籤、官方連結與雪道資料。雪季營業時間、票價與雪況可能依年度調整，出發前請再以各雪場官方公告為準。
      </p>
    </section>

    <ListingFilterNav
      prefectureStats={prefectureStats}
      tagStats={tagStats}
      basePath="/resorts/"
    />

    <ResortSearchResults
      resorts={resorts}
      regionNamesByKey={regionNamesByKey}
      sourceArea="resort_index"
    />
  </main>
</BaseLayout>
