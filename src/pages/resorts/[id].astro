---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { regions } from '../../data/regions'
import { tagLabels } from '../../data/tags'
import { filterPublishedResorts } from '../../utils/resorts'
import { withBasePath } from '../../utils/paths'

export async function getStaticPaths() {
  const resorts = filterPublishedResorts(await getCollection('resorts'))

  return resorts.map((resort) => ({
    params: { id: resort.id },
    props: { resort },
  }))
}

const { resort } = Astro.props
const { Content } = await render(resort)
const region = regions.find((item) => item.key === resort.data.region)

const primaryLinks = [
  ['官方網站', resort.data.links.official],
  ['交通資訊', resort.data.links.access],
  ['雪道圖', resort.data.links.trailMapPage],
  ['票券資訊', resort.data.links.ticket],
  ['Google Maps', resort.data.links.googleMaps],
].filter((item): item is [string, string] => Boolean(item[1]))

const hasExternalContent =
  (resort.data.externalContent?.blogs?.length ?? 0) > 0 ||
  (resort.data.externalContent?.vlogs?.length ?? 0) > 0
---

<BaseLayout
  title={`${resort.data.name.zhTw} | 日本滑雪場指南`}
  description={`${resort.data.name.zhTw} 的穩定資料、分類標籤與官方資訊連結。`}
>
  <main class="site-shell page-stack">
    <a class="text-link" href={withBasePath('/resorts/')}>回滑雪場列表</a>

    <section class="detail-hero" aria-labelledby="page-title">
      <div>
        <p class="eyebrow">{region?.name.zhTw ?? resort.data.region} / {resort.data.prefecture}</p>
        <h1 id="page-title">{resort.data.name.zhTw}</h1>
        <p class="detail-hero__names">
          {resort.data.name.ja}
          {resort.data.name.en && <span>{resort.data.name.en}</span>}
        </p>
      </div>
      <div class="tag-list tag-list--large" aria-label={`${resort.data.name.zhTw} tags`}>
        {resort.data.tags.map((tag) => (
          <span>{tagLabels[tag]}</span>
        ))}
      </div>
    </section>

    <section class="resort-actions" aria-label="主要連結">
      {primaryLinks.map(([label, url]) => (
        <a href={url} target="_blank" rel="noreferrer">{label}</a>
      ))}
      {resort.data.courses?.courseInfoPage && (
        <a href={withBasePath(`/resorts/${resort.id}/courses/`)}>雪道資訊</a>
      )}
    </section>

    <section class="resort-detail-layout">
      <article class="info-panel detail-panel resort-summary">
        <h2>概要</h2>
        <div class="content-body">
          <Content />
        </div>
      </article>

      {
        resort.data.contact && (
          <section class="info-panel detail-panel">
            <h2>重點資訊</h2>
            <dl class="fact-list">
              <div>
                <dt>地址</dt>
                <dd>
                  <span>{resort.data.contact.address.zhTw}</span>
                  <span>{resort.data.contact.address.ja}</span>
                  <a href={resort.data.contact.address.googleMaps} target="_blank" rel="noreferrer">
                    Google Maps
                  </a>
                </dd>
              </div>
              {resort.data.contact.phone && (
                <div>
                  <dt>電話</dt>
                  <dd>{resort.data.contact.phone}</dd>
                </div>
              )}
              <div>
                <dt>官方網站</dt>
                <dd>
                  <a href={resort.data.links.official} target="_blank" rel="noreferrer">
                    {resort.data.name.en ?? resort.data.name.zhTw}
                  </a>
                </dd>
              </div>
            </dl>
          </section>
        )
      }

      {
        resort.data.season && (
          <section class="info-panel detail-panel">
            <h2>營業日期與時間</h2>
            <dl class="fact-list">
              <div>
                <dt>雪季</dt>
                <dd>{resort.data.season.label}</dd>
              </div>
              {resort.data.season.operatingPeriod && (
                <div>
                  <dt>期間</dt>
                  <dd>{resort.data.season.operatingPeriod}</dd>
                </div>
              )}
              {resort.data.season.hours && (
                <div>
                  <dt>日間</dt>
                  <dd>{resort.data.season.hours}</dd>
                </div>
              )}
              {resort.data.season.nightSkiingHours && (
                <div>
                  <dt>夜滑</dt>
                  <dd>{resort.data.season.nightSkiingHours}</dd>
                </div>
              )}
            </dl>
            {resort.data.season.note && <p class="panel-note">{resort.data.season.note}</p>}
          </section>
        )
      }

      {
        resort.data.tickets && (
          <section class="info-panel detail-panel detail-panel--wide">
            <div class="section-heading-row">
              <h2>主要票種</h2>
              <a href={resort.data.tickets.source} target="_blank" rel="noreferrer">
                官方票價
              </a>
            </div>
            <div class="ticket-grid">
              {resort.data.tickets.plans.map((plan) => (
                <article class="ticket-card">
                  <p>{plan.audience}</p>
                  <h3>{plan.name}</h3>
                  <strong>{plan.price}</strong>
                  {plan.note && <small>{plan.note}</small>}
                </article>
              ))}
            </div>
            {resort.data.tickets.note && <p class="panel-note">{resort.data.tickets.note}</p>}
          </section>
        )
      }

      {
        resort.data.trailMaps && resort.data.trailMaps.length > 0 && (
          <section class="info-panel detail-panel">
            <h2>雪場圖</h2>
            <ul class="resource-list">
              {resort.data.trailMaps.map((map) => (
                <li>
                  <div>
                    <strong>{map.label}</strong>
                    <span>{[map.language, map.season].filter(Boolean).join(' / ')}</span>
                  </div>
                  <a href={map.url} target="_blank" rel="noreferrer">開啟 PDF</a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        resort.data.courses?.courseInfoPage && (
          <section class="info-panel detail-panel">
            <h2>雪道資訊</h2>
            <p class="panel-note">{resort.data.courses.summary ?? '雪道資料整理中。'}</p>
            <div class="inline-actions">
              <a href={withBasePath(`/resorts/${resort.id}/courses/`)}>查看雪道頁面</a>
              <a href={resort.data.courses.courseInfoPage} target="_blank" rel="noreferrer">
                官方雪道資訊
              </a>
            </div>
          </section>
        )
      }

      {
        hasExternalContent && (
          <section class="info-panel detail-panel">
            <h2>其他資訊</h2>
            {resort.data.externalContent?.blogs && resort.data.externalContent.blogs.length > 0 && (
              <>
                <h3 class="subsection-title">BLOG</h3>
                <ul class="link-list">
                  {resort.data.externalContent.blogs.map((blog) => (
                    <li>
                      <a href={blog.url} target="_blank" rel="noreferrer">{blog.title}</a>
                    </li>
                  ))}
                </ul>
              </>
            )}
            {resort.data.externalContent?.vlogs && resort.data.externalContent.vlogs.length > 0 && (
              <>
                <h3 class="subsection-title">VLOG</h3>
                <ul class="link-list">
                  {resort.data.externalContent.vlogs.map((vlog) => (
                    <li>
                      <a href={vlog.url} target="_blank" rel="noreferrer">{vlog.title}</a>
                    </li>
                  ))}
                </ul>
              </>
            )}
          </section>
        )
      }

      <aside class="info-panel detail-panel">
        <h2>資料來源</h2>
        <ul class="link-list">
          {resort.data.sources.map((source) => (
            <li>
              <a href={source.url} target="_blank" rel="noreferrer">{source.label}</a>
            </li>
          ))}
        </ul>
      </aside>
    </section>
  </main>
</BaseLayout>
