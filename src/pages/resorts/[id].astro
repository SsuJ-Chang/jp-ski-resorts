---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { regions } from '../../data/regions'
import { tagLabels } from '../../data/tags'
import { filterPublishedResorts } from '../../utils/resorts'
import { withBasePath } from '../../utils/paths'

export async function getStaticPaths() {
  const resorts = filterPublishedResorts(await getCollection('resorts'))

  return resorts.map((resort) => ({
    params: { id: resort.id },
    props: { resort },
  }))
}

const { resort } = Astro.props
const { Content } = await render(resort)
const region = regions.find((item) => item.key === resort.data.region)

const primaryLinks = [
  ['官方網站', resort.data.links.official],
  ['交通資訊', resort.data.links.access],
  ['雪道圖', resort.data.links.trailMapPage],
  ['票券資訊', resort.data.links.ticket],
  ['Google Maps', resort.data.links.googleMaps],
].filter((item): item is [string, string] => Boolean(item[1]))
---

<BaseLayout
  title={`${resort.data.name.zhTw} | JP Ski Resorts`}
  description={`${resort.data.name.zhTw} 的穩定資料、分類標籤與官方資訊連結。`}
>
  <main class="site-shell page-stack">
    <a class="text-link" href={withBasePath('/resorts/')}>回滑雪場列表</a>

    <section class="detail-hero" aria-labelledby="page-title">
      <div>
        <p class="eyebrow">{region?.name.zhTw ?? resort.data.region} / {resort.data.prefecture}</p>
        <h1 id="page-title">{resort.data.name.zhTw}</h1>
        <p class="detail-hero__names">
          {resort.data.name.ja}
          {resort.data.name.en && <span>{resort.data.name.en}</span>}
        </p>
      </div>
      <div class="tag-list tag-list--large" aria-label={`${resort.data.name.zhTw} tags`}>
        {resort.data.tags.map((tag) => (
          <span>{tagLabels[tag]}</span>
        ))}
      </div>
    </section>

    <section class="detail-grid">
      <article class="info-panel detail-panel">
        <h2>概要</h2>
        <div class="content-body">
          <Content />
        </div>
      </article>

      <aside class="info-panel detail-panel">
        <h2>官方連結</h2>
        <ul class="link-list">
          {primaryLinks.map(([label, url]) => (
            <li>
              <a href={url} target="_blank" rel="noreferrer">{label}</a>
            </li>
          ))}
        </ul>
      </aside>

      <aside class="info-panel detail-panel">
        <h2>資料來源</h2>
        <ul class="link-list">
          {resort.data.sources.map((source) => (
            <li>
              <a href={source.url} target="_blank" rel="noreferrer">{source.label}</a>
            </li>
          ))}
        </ul>
      </aside>
    </section>
  </main>
</BaseLayout>
