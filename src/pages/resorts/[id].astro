---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { regions } from '../../data/regions'
import { publishedSkiAreaKeys, skiAreas } from '../../data/skiAreas'
import { tagLabels } from '../../data/tags'
import { filterPublishedResorts } from '../../utils/resorts'
import { withBasePath } from '../../utils/paths'

export async function getStaticPaths() {
  const resorts = filterPublishedResorts(await getCollection('resorts'))

  return resorts.map((resort) => ({
    params: { id: resort.id },
    props: { resort },
  }))
}

const { resort } = Astro.props
const { Content } = await render(resort)
const region = regions.find((item) => item.key === resort.data.region)
const publishedSkiAreaSet = new Set<string>(publishedSkiAreaKeys)
const skiArea =
  resort.data.skiArea && publishedSkiAreaSet.has(resort.data.skiArea)
    ? skiAreas[resort.data.skiArea]
    : undefined

const hasExternalContent =
  (resort.data.externalContent?.blogs?.length ?? 0) > 0 ||
  (resort.data.externalContent?.vlogs?.length ?? 0) > 0

const isDisplayableSnowDepth = (value?: string) => {
  const normalizedValue = value?.trim()

  if (!normalizedValue) {
    return false
  }

  return (
    !['-', 'N/A', 'n/a', '未提供', '待補', '待確認', 'to be filled'].includes(normalizedValue) &&
    !/^0\s*(cm|公分)?$/i.test(normalizedValue)
  )
}

const snowWeather = resort.data.snowWeather
const snowWeatherForecast = snowWeather?.forecast ?? []
const hasSnowDepth = isDisplayableSnowDepth(snowWeather?.snowDepth)
const hasWeatherForecast = snowWeatherForecast.length > 0
const shouldShowSnowWeather = Boolean(snowWeather && (hasSnowDepth || hasWeatherForecast))

const courseDifficultyRatios = [
  {
    key: 'beginner',
    label: '初級',
    ratio: resort.data.courses?.beginnerRatio,
  },
  {
    key: 'intermediate',
    label: '中級',
    ratio: resort.data.courses?.intermediateRatio,
  },
  {
    key: 'advanced',
    label: '進階',
    ratio: resort.data.courses?.advancedRatio,
  },
].filter(
  (
    level,
  ): level is {
    key: string
    label: string
    ratio: number
  } => level.ratio !== undefined,
)

let courseDifficultyCursor = 0
const courseDifficultySegments = courseDifficultyRatios.map((level) => {
  const start = courseDifficultyCursor
  const end = Math.min(100, start + Math.max(level.ratio, 0))
  courseDifficultyCursor = end

  return { ...level, start, end }
})

const hasCourseDifficultyRatios = courseDifficultyRatios.length > 0
const hasCourseSummary =
  Boolean(resort.data.courses?.summary) || hasCourseDifficultyRatios || Boolean(resort.data.courses?.courseInfoPage)
const courseDifficultyLabel = courseDifficultyRatios
  .map((level) => `${level.label} ${level.ratio}%`)
  .join('、')

const formatNumber = (value: number) => new Intl.NumberFormat('zh-Hant-TW').format(value)
const elevation = resort.data.elevation
const hasElevationOverview = elevation?.top !== undefined || elevation?.bottom !== undefined
const elevationLabel = [
  elevation?.top !== undefined ? `top ${formatNumber(elevation.top)}m` : undefined,
  elevation?.bottom !== undefined ? `bottom ${formatNumber(elevation.bottom)}m` : undefined,
]
  .filter(Boolean)
  .join('、')
const accessRouteGroups = [
  { origin: '東京出發', routes: resort.data.access?.fromTokyo },
  { origin: '大阪出發', routes: resort.data.access?.fromOsaka },
  { origin: '名古屋出發', routes: resort.data.access?.fromNagoya },
  { origin: '札幌出發', routes: resort.data.access?.fromSapporo },
  { origin: '機場出發', routes: resort.data.access?.fromAirport },
]
const accessRoutes = accessRouteGroups.flatMap((group) =>
  (group.routes ?? []).map((route) => ({
    origin: group.origin,
    route,
  })),
)
const carAccess = resort.data.access?.car
const hasAccessInfo = accessRoutes.length > 0 || Boolean(carAccess)
const getAccessTimeLabel = (estimatedTime?: string) => estimatedTime?.split(/[，,、]/)[0]?.trim() ?? ''

const resortCanonicalPath = `/resorts/${resort.id}/`
const resortDescriptionParts = [
  `${resort.data.name.zhTw}滑雪場資料`,
  resort.data.prefecture,
  region?.name.zhTw,
  skiArea ? `${skiArea.name.zhTw}雪場區域` : undefined,
  resort.data.courses?.summary,
]
  .filter(Boolean)
  .filter((part, index, parts) => parts.indexOf(part) === index)

const resortDescription = resortDescriptionParts
  .join('，')
  .slice(0, 155)
const siteUrl = Astro.site ?? new URL('https://jp-resorts.rj-tw.com')
const resortUrl = new URL(resortCanonicalPath, siteUrl).toString()
const resortStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'SportsActivityLocation',
    name: resort.data.name.zhTw,
    alternateName: [
      resort.data.name.ja,
      resort.data.name.en,
    ].filter(Boolean),
    url: resortUrl,
    sameAs: resort.data.links.official,
    description: resortDescription,
    telephone: resort.data.contact?.phone,
    address: resort.data.contact && {
      '@type': 'PostalAddress',
      addressCountry: 'JP',
      addressRegion: resort.data.prefecture,
      streetAddress: resort.data.contact.address.zhTw,
    },
    geo: resort.data.location && {
      '@type': 'GeoCoordinates',
      latitude: resort.data.location.latitude,
      longitude: resort.data.location.longitude,
    },
    openingHoursSpecification: resort.data.season?.hours && {
      '@type': 'OpeningHoursSpecification',
      description: resort.data.season.hours,
    },
    additionalProperty: [
      resort.data.courses?.total !== undefined && {
        '@type': 'PropertyValue',
        name: '雪道數',
        value: resort.data.courses.total,
      },
      resort.data.lifts?.total !== undefined && {
        '@type': 'PropertyValue',
        name: '纜車數',
        value: resort.data.lifts.total,
      },
      elevation?.top !== undefined && {
        '@type': 'PropertyValue',
        name: '最高標高',
        value: elevation.top,
        unitText: 'm',
      },
      elevation?.bottom !== undefined && {
        '@type': 'PropertyValue',
        name: '最低標高',
        value: elevation.bottom,
        unitText: 'm',
      },
    ].filter(Boolean),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: '首頁',
        item: new URL('/', siteUrl).toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: '滑雪場',
        item: new URL('/resorts/', siteUrl).toString(),
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: resort.data.name.zhTw,
        item: resortUrl,
      },
    ],
  },
]
---

<BaseLayout
  title={`${resort.data.name.zhTw} | 日本滑雪場指南`}
  description={resortDescription}
  canonicalPath={resortCanonicalPath}
  structuredData={resortStructuredData}
>
  <main
    class="site-shell page-stack"
    data-analytics-view="resort"
    data-resort-slug={resort.id}
    data-resort-region={resort.data.region}
    data-resort-prefecture={resort.data.prefecture}
  >
    <a class="text-link" href={withBasePath('/resorts/')}>回滑雪場列表</a>

    <section class="detail-hero" aria-labelledby="page-title">
      <div>
        <p class="eyebrow">{region?.name.zhTw ?? resort.data.region} / {resort.data.prefecture}</p>
        <h1 id="page-title">{resort.data.name.zhTw}</h1>
        <p class="detail-hero__names">
          {resort.data.name.ja}
          {resort.data.name.en && <span>{resort.data.name.en}</span>}
        </p>
        {skiArea && (
          <a
            class="ski-area-pill-link"
            href={withBasePath(`/ski-areas/${skiArea.key}/`)}
            data-analytics-select="ski_area"
            data-select-id={skiArea.key}
            data-source-area="resort_detail"
          >
            雪場區域：{skiArea.name.zhTw}
          </a>
        )}
      </div>
      <div class="tag-list tag-list--large" aria-label={`${resort.data.name.zhTw} tags`}>
        {resort.data.tags.map((tag) => (
          <span>{tagLabels[tag]}</span>
        ))}
      </div>
    </section>

    <section class="resort-detail-layout">
      <article class="info-panel detail-panel resort-summary">
        <h2>概要</h2>
        <div class="content-body">
          <Content />
        </div>
      </article>

      {
        resort.data.contact && (
          <section class="info-panel detail-panel">
            <h2>基本資訊</h2>
            <dl class="fact-list">
              <div>
                <dt>地址</dt>
                <dd>
                  <span>{resort.data.contact.address.zhTw}</span>
                  <span>{resort.data.contact.address.ja}</span>
                  <a
                    href={resort.data.contact.address.googleMaps}
                    target="_blank"
                    rel="noreferrer"
                    data-analytics-resource="google_maps"
                    data-analytics-label="Google Maps"
                  >
                    Google Maps
                  </a>
                </dd>
              </div>
              {resort.data.contact.phone && (
                <div>
                  <dt>電話</dt>
                  <dd>{resort.data.contact.phone}</dd>
                </div>
              )}
              <div>
                <dt>官方網站</dt>
                <dd>
                  <a
                    href={resort.data.links.official}
                    target="_blank"
                    rel="noreferrer"
                    data-analytics-resource="official_site"
                    data-analytics-label={`${resort.data.name.zhTw}官方網站`}
                  >
                    {resort.data.name.en ?? resort.data.name.zhTw}
                  </a>
                </dd>
              </div>
            </dl>
          </section>
        )
      }

      {
        resort.data.season && (
          <section class="info-panel detail-panel">
            <h2>營業日期與時間</h2>
            <dl class="fact-list">
              <div>
                <dt>雪季</dt>
                <dd>{resort.data.season.label}</dd>
              </div>
              {resort.data.season.operatingPeriod && (
                <div>
                  <dt>期間</dt>
                  <dd>{resort.data.season.operatingPeriod}</dd>
                </div>
              )}
              {resort.data.season.hours && (
                <div>
                  <dt>日間</dt>
                  <dd>{resort.data.season.hours}</dd>
                </div>
              )}
              {resort.data.season.nightSkiingHours && (
                <div>
                  <dt>夜滑</dt>
                  <dd>{resort.data.season.nightSkiingHours}</dd>
                </div>
              )}
            </dl>
            {resort.data.season.note && <p class="panel-note">{resort.data.season.note}</p>}
          </section>
        )
      }

      {
        hasAccessInfo && (
          <section class="info-panel detail-panel detail-panel--wide access-panel" aria-labelledby="access-heading">
            <div class="section-heading-row">
              <h2 id="access-heading">交通方式</h2>
              {resort.data.links.access && (
                <a
                  href={resort.data.links.access}
                  target="_blank"
                  rel="noreferrer"
                  data-analytics-resource="official_access"
                  data-analytics-label="官方交通資訊"
                >
                  官方交通資訊
                </a>
              )}
            </div>
            <div class="access-grid">
              {accessRoutes.map((item) => (
                <article class="access-card">
                  <div class="access-card__header">
                    <div>
                      <p class="access-card__origin">{item.origin}</p>
                      <h3>{item.route.label}</h3>
                    </div>
                    {item.route.estimatedTime && (
                      <div class="access-card__badges">
                        <span title={item.route.estimatedTime} aria-label={item.route.estimatedTime}>
                          {getAccessTimeLabel(item.route.estimatedTime)}
                        </span>
                      </div>
                    )}
                  </div>
                  <ol class="access-steps">
                    {item.route.steps.map((step) => (
                      <li>{step}</li>
                    ))}
                  </ol>
                  {item.route.note && <p class="access-card__note">{item.route.note}</p>}
                </article>
              ))}
              {carAccess && (
                <article class="access-card">
                  <div class="access-card__header">
                    <div>
                      <p class="access-card__origin">自駕</p>
                      <h3>開車前往</h3>
                    </div>
                    <div class="access-card__badges">
                      <span>{carAccess.recommended ? '建議自駕' : '大眾運輸優先'}</span>
                      <span>{carAccess.snowTireRequired ? '需雪胎／雪鏈' : '依路況準備防滑裝備'}</span>
                    </div>
                  </div>
                  {carAccess.note && <p class="access-card__note">{carAccess.note}</p>}
                </article>
              )}
            </div>
          </section>
        )
      }

      {
        resort.data.tickets && (
          <section class="info-panel detail-panel detail-panel--wide">
            <div class="section-heading-row">
              <h2>主要票種</h2>
              <a
                href={resort.data.tickets.source}
                target="_blank"
                rel="noreferrer"
                data-analytics-resource="ticket_price"
                data-analytics-label="官方票價"
                data-analytics-note={resort.data.tickets.note}
              >
                官方票價
              </a>
            </div>
            <div class="ticket-grid">
              {resort.data.tickets.plans.map((plan) => (
                <article class="ticket-card">
                  <p>{plan.audience}</p>
                  <h3>{plan.name}</h3>
                  <strong>{plan.price}</strong>
                  {plan.note && <small>{plan.note}</small>}
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        ((resort.data.trailMaps && resort.data.trailMaps.length > 0) ||
          resort.data.courses?.courseInfoPage ||
          hasCourseSummary ||
          hasElevationOverview) && (
          <section class="info-panel detail-panel detail-panel--wide">
            <div class="section-heading-row">
              <h2>雪道與地形資訊</h2>
              {resort.data.courses?.courseInfoPage && (
                <a
                  href={resort.data.courses.courseInfoPage}
                  target="_blank"
                  rel="noreferrer"
                  data-analytics-resource="official_courses"
                  data-analytics-label="官方雪道資訊"
                >
                  官方雪道資訊
                </a>
              )}
            </div>
            {hasCourseSummary && (
              <div class="resource-section course-overview">
                <p class="panel-note">{resort.data.courses?.summary ?? '雪道資料整理中。'}</p>
              </div>
            )}
            {(hasElevationOverview || hasCourseDifficultyRatios) && (
              <div
                class:list={[
                  'resource-section',
                  'terrain-visual-row',
                  hasCourseDifficultyRatios && hasElevationOverview && 'terrain-visual-row--paired',
                ]}
              >
                {hasCourseDifficultyRatios && (
                  <div class="course-difficulty-chart" aria-label={`雪道難度比例：${courseDifficultyLabel}`}>
                    <div class="course-difficulty-chart__pie" aria-hidden="true">
                      {courseDifficultySegments.map((segment) => (
                        <span
                          class={`course-difficulty-chart__slice course-difficulty-chart__slice--${segment.key}`}
                          style={`--slice-start: ${segment.start}%; --slice-end: ${segment.end}%;`}
                        />
                      ))}
                    </div>
                    <div class="course-difficulty-chart__labels" aria-hidden="true">
                      {courseDifficultyRatios.map((level) => (
                        <span class={`course-difficulty-chart__label course-difficulty-chart__label--${level.key}`}>
                          {level.label} {level.ratio}%
                        </span>
                      ))}
                    </div>
                  </div>
                )}
                {hasElevationOverview && (
                  <figure class="elevation-mountain" role="img" aria-label={`${resort.data.name.zhTw} 標高：${elevationLabel}`}>
                    <div class="elevation-mountain__canvas">
                      <svg class="elevation-mountain__svg" viewBox="0 0 260 160" aria-hidden="true">
                        <polygon class="elevation-mountain__shape elevation-mountain__shape--top" points="136 26 40 148 232 148" />
                        <polyline class="elevation-mountain__ridge" points="136 26 40 148 232 148 136 26" />
                        <polygon class="elevation-mountain__shape elevation-mountain__shape--bottom" points="78 76 21 148 135 148" />
                        <polyline class="elevation-mountain__ridge elevation-mountain__ridge--bottom" points="78 76 21 148 135 148 78 76" />
                      </svg>
                      <div class="elevation-mountain__values" aria-hidden="true">
                        {elevation?.top !== undefined && (
                          <span class="elevation-mountain__value elevation-mountain__value--top">
                            {formatNumber(elevation.top)}m
                          </span>
                        )}
                        {elevation?.bottom !== undefined && (
                          <span class="elevation-mountain__value elevation-mountain__value--bottom">
                            {formatNumber(elevation.bottom)}m
                          </span>
                        )}
                      </div>
                    </div>
                  </figure>
                )}
              </div>
            )}
            {resort.data.courses?.courseInfoPage && (
              <div class="resource-section resource-detail-actions">
                <a
                  class="text-link resource-detail-link"
                  href={withBasePath(`/resorts/${resort.id}/courses/`)}
                  data-analytics-select="resort_courses"
                  data-select-id={resort.id}
                  data-source-area="resort_detail"
                >
                  雪道詳細資訊
                </a>
              </div>
            )}
            {resort.data.trailMaps && resort.data.trailMaps.length > 0 && (
              <div class="resource-section">
                <ul class="resource-list">
                  {resort.data.trailMaps.map((map) => (
                    <li>
                      <div>
                        <a
                          href={map.url}
                          target="_blank"
                          rel="noreferrer"
                          data-analytics-resource="trail_map"
                          data-analytics-label={map.label}
                          data-analytics-note={[map.sourceLabel, map.season].filter(Boolean).join(' / ')}
                        >
                          {map.label}
                        </a>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </section>
        )
      }

      {
        snowWeather && shouldShowSnowWeather && (
          <section class="info-panel detail-panel detail-panel--wide snow-weather-panel">
            <h2>雪況天氣</h2>
            <>
              {hasSnowDepth && (
                <div class="weather-summary">
                  <div>
                    <span>積雪量</span>
                    <strong>{snowWeather.snowDepth}</strong>
                  </div>
                </div>
              )}
              {hasWeatherForecast && (
                <div class="weather-table-wrap" aria-label={`${resort.data.name.zhTw} 一週天氣`}>
                  <table class="weather-table">
                    <tbody>
                      <tr>
                        {snowWeatherForecast.map((day) => (
                          <th scope="col">{day.date}</th>
                        ))}
                      </tr>
                      <tr>
                        {snowWeatherForecast.map((day) => (
                          <td>{day.weather}</td>
                        ))}
                      </tr>
                      <tr>
                        {snowWeatherForecast.map((day) => (
                          <td>{day.high}</td>
                        ))}
                      </tr>
                      <tr>
                        {snowWeatherForecast.map((day) => (
                          <td>{day.low}</td>
                        ))}
                      </tr>
                    </tbody>
                  </table>
                </div>
              )}
              {snowWeather.updatedAt && (
                <p class="weather-updated">更新時間：{snowWeather.updatedAt}</p>
              )}
              <p class="resource-provider">
                資料來源：
                <a
                  href={snowWeather.url}
                  target="_blank"
                  rel="noreferrer"
                  data-analytics-resource="snow_weather"
                  data-analytics-label={snowWeather.provider ?? snowWeather.title}
                  data-analytics-note={snowWeather.note}
                >
                  {snowWeather.provider ?? snowWeather.title}
                </a>
              </p>
            </>
          </section>
        )
      }

      {
        hasExternalContent && (
          <section class="info-panel detail-panel detail-panel--wide external-content-panel">
            <h2>其他資訊</h2>
            {resort.data.externalContent?.blogs && resort.data.externalContent.blogs.length > 0 && (
              <>
                <h3 class="subsection-title">遊記</h3>
                <ul class="link-list">
                  {resort.data.externalContent.blogs.map((blog) => (
                    <li>
                      <a
                        href={blog.url}
                        target="_blank"
                        rel="noreferrer"
                        data-analytics-resource="blog"
                        data-analytics-label={blog.title}
                        data-analytics-note={blog.note}
                      >
                        {blog.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )}
            {resort.data.externalContent?.vlogs && resort.data.externalContent.vlogs.length > 0 && (
              <>
                <h3 class="subsection-title">影片</h3>
                <ul class="link-list">
                  {resort.data.externalContent.vlogs.map((vlog) => (
                    <li>
                      <a
                        href={vlog.url}
                        target="_blank"
                        rel="noreferrer"
                        data-analytics-resource="vlog"
                        data-analytics-label={vlog.title}
                        data-analytics-note={vlog.note}
                      >
                        {vlog.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            )}
          </section>
        )
      }
    </section>
  </main>
</BaseLayout>
