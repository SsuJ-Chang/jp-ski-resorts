---
import BaseLayout from '../layouts/BaseLayout.astro'
import { withBasePath } from '../utils/paths'

const privacyCards = [
  {
    eyebrow: '資料範圍',
    title: '本站不直接收集姓名、電話或帳號',
    description:
      '目前網站沒有會員系統、留言功能或表單資料庫，也不會要求你提供姓名、電話、帳號或身分證資料。',
  },
  {
    eyebrow: '分析用途',
    title: '使用 Google Analytics 4 觀察流量',
    description:
      '本站使用 GA4 了解搜尋是否被使用、哪些雪場頁面較常被瀏覽，以及使用者是否會透過縣別或區域繼續探索。',
  },
  {
    eyebrow: '分析用途',
    title: '事件資料用來優化站內內容',
    description:
      '像外部連結點擊、雪道資訊查看與頁面瀏覽等事件，主要用來判斷哪些內容真的有被使用，而不是辨識特定個人。',
  },
  {
    eyebrow: 'Cookie',
    title: '分析工具可能使用 Cookie 或類似技術',
    description:
      '這些技術主要用於辨識瀏覽器、統計互動行為與提升報表可讀性，不會讓站長直接看到你的真實身分。',
  },
  {
    eyebrow: '第三方服務',
    title: '目前以 Google Analytics 4 為主',
    description:
      '本站目前重點是流量與使用行為分析。若未來加入其他第三方服務，例如廣告或更多分析工具，會在本頁更新說明。',
  },
  {
    eyebrow: '自行管理',
    title: '你可以封鎖或刪除 Cookie',
    description:
      '如果你不希望被記錄分析資料，可以在瀏覽器中封鎖、清除 Cookie，或使用瀏覽器的隱私模式與追蹤防護設定。這和你平常清掉登入狀態或限制網站追蹤是同樣概念。',
  },
  {
    eyebrow: '政策更新',
    title: '若網站功能調整，政策會一起更新',
    description:
      '如果本站未來新增廣告、表單、更多分析事件或其他第三方工具，這份政策會同步更新。最後更新日期：2026-06-25。',
  },
  {
    eyebrow: '聯絡方式',
    title: '對政策內容有疑問時',
    description: '如果你對本站如何使用分析資料、事件追蹤範圍或政策文字有疑問，可以前往',
    href: withBasePath('/contact/'),
    linkText: '聯絡作者',
    descriptionSuffix: '頁提出。',
  },
]

const privacyStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: '隱私權政策｜日本滑雪場指南',
  description: '說明日本滑雪場指南目前使用的分析工具、Cookie 與網站不直接收集的個人資料範圍。',
  inLanguage: 'zh-Hant-TW',
}
---

<BaseLayout
  title="隱私權政策｜日本滑雪場指南"
  description="說明日本滑雪場指南目前使用的分析工具、Cookie 與網站不直接收集的個人資料範圍。"
  bodyClass="privacy-page"
  canonicalPath="/privacy/"
  structuredData={privacyStructuredData}
>
  <main class="site-shell page-stack privacy-shell">
    <section class="page-heading privacy-hero" aria-labelledby="privacy-title">
      <p class="eyebrow">Privacy policy</p>
      <h1 id="privacy-title">隱私權政策</h1>
      <p>
        本頁說明日本滑雪場指南目前如何使用分析工具、Cookie 與匿名化流量資料。重點是讓你知道哪些互動可能被統計、這些資料會被拿來做什麼，以及你可以如何自行管理。
      </p>
    </section>

    <section class="footer-page-section" aria-label="隱私權政策內容">
      <ol class="footer-page-list">
        {privacyCards.map((card, index) => (
          <li class="footer-page-card" style={`--index: ${index}`}>
            <div class="footer-page-card__meta">
              <p class="footer-page-card__eyebrow">{card.eyebrow}</p>
            </div>
            <div class="footer-page-card__content">
              <h2 class="footer-page-card__title">{card.title}</h2>
              <p class="footer-page-card__description">
                {card.description}
                {card.href && card.linkText && (
                  <>
                    <a class="text-link" href={card.href}> {card.linkText} </a>
                    {card.descriptionSuffix}
                  </>
                )}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </main>
</BaseLayout>
