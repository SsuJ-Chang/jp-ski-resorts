---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import { regions } from '../data/regions'
import { filterPublishedResorts } from '../utils/resorts'
import { withBasePath } from '../utils/paths'

const toneByRegion = {
  hokkaido: 'powder',
  tohoku: 'snow',
  'kanto-koshinetsu': 'access',
  hokuriku: 'coast',
  chubu: 'alps',
  'kansai-chugoku': 'weekend',
  kyushu: 'south',
} as const

const resorts = filterPublishedResorts(await getCollection('resorts'))

const regionStats = regions.map((region) => {
  const regionResorts = resorts
    .filter((resort) => resort.data.region === region.key)
    .sort((a, b) => a.data.name.zhTw.localeCompare(b.data.name.zhTw, 'zh-Hant-TW'))

  return {
    ...region,
    tone: toneByRegion[region.key],
    count: regionResorts.length,
    examples: regionResorts.map((resort) => resort.data.name.zhTw),
  }
})

const mapRegionClass = {
  hokkaido: 'map-region--hokkaido',
  tohoku: 'map-region--tohoku',
  'kanto-koshinetsu': 'map-region--kanto',
  hokuriku: 'map-region--hokuriku',
  chubu: 'map-region--chubu',
  'kansai-chugoku': 'map-region--kansai',
  kyushu: 'map-region--kyushu',
} as const
---

<BaseLayout title="日本滑雪場指南" bodyClass="home-page">
  <main class="site-shell">
    <section class="hero" aria-labelledby="page-title">
      <div class="hero__copy">
        <p class="eyebrow">Japan ski guide</p>
        <h1 id="page-title" class="hero-title">日本滑雪場指南</h1>
        <p class="hero__lead">
          面向台灣滑雪者的日本滑雪場資料庫。先整理穩定資訊、區域導覽、交通摘要與官方連結，再逐步擴充成可維護的靜態網站。
        </p>
      </div>
      <div class="hero__guide" aria-label="Japan ski region guide">
        <input class="view-toggle-input" id="region-view-list" type="radio" name="region-view" checked />
        <input class="view-toggle-input" id="region-view-map" type="radio" name="region-view" />

        <div class="view-toggle" aria-label="Region view mode">
          <label for="region-view-list">列表</label>
          <label for="region-view-map">地圖</label>
        </div>

        <div class="region-list-view">
          {regionStats.map((region, index) => (
            <a
              class={`region-strip region-strip--${region.tone}`}
              href={withBasePath(`/regions/${region.key}/`)}
              style={`--index: ${index}`}
            >
              <span>{region.name.zhTw}</span>
              <small>
                {region.count} 間
                {region.examples.length > 0 && ` / ${region.examples.slice(0, 2).join('、')}`}
              </small>
            </a>
          ))}
        </div>

        <div class="region-map-view" aria-label="日本滑雪分區地圖">
          <div class="japan-region-map">
            {regionStats.map((region) => (
              <a
                class={`map-region ${mapRegionClass[region.key]} region-strip--${region.tone}`}
                href={withBasePath(`/regions/${region.key}/`)}
                aria-label={`${region.name.zhTw}，目前收錄 ${region.count} 間滑雪場`}
              >
                <span>{region.name.zhTw}</span>
                <small>{region.count} 間</small>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
