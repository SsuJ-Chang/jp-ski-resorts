---
import BaseLayout from '../layouts/BaseLayout.astro'
import JapanRegionMap from '../components/JapanRegionMap.astro'
import { regions } from '../data/regions'
import { getPublishedResorts } from '../utils/resortCatalog'
import { withBasePath } from '../utils/paths'
import { getPublishedSkiAreas } from '../utils/skiAreas'
import { tagLabels, type ResortTag } from '../data/tags'

const toneByRegion = {
  hokkaido: 'powder',
  tohoku: 'snow',
  'kanto-koshinetsu': 'access',
  hokuriku: 'coast',
  chubu: 'alps',
  'kansai-chugoku': 'weekend',
  kyushu: 'south',
} as const

const resorts = await getPublishedResorts()
const skiAreas = await getPublishedSkiAreas()
const resortCount = resorts.length
const homeQuickTags: Array<{
  tag: ResortTag
  tone: 'learn' | 'trip' | 'powder'
}> = [
  {
    tag: 'beginner_friendly',
    tone: 'learn',
  },
  {
    tag: 'good_for_first_japan_trip',
    tone: 'trip',
  },
  {
    tag: 'powder',
    tone: 'powder',
  },
]
const regionExampleLimit = 2
const regionExampleCollator = new Intl.Collator('zh-Hant-TW')
type Resort = (typeof resorts)[number]

const featuredResortOrder = new Map<string, number>()

skiAreas.forEach((area, areaIndex) => {
  area.featuredResorts.forEach((resortId, resortIndex) => {
    featuredResortOrder.set(resortId, areaIndex * 100 + resortIndex)
  })
})

const sortRegionExamples = (a: Resort, b: Resort) => {
  const orderA = featuredResortOrder.get(a.id) ?? Number.MAX_SAFE_INTEGER
  const orderB = featuredResortOrder.get(b.id) ?? Number.MAX_SAFE_INTEGER

  if (orderA !== orderB) {
    return orderA - orderB
  }

  return regionExampleCollator.compare(a.data.name.zhTw, b.data.name.zhTw)
}

// 首頁範例雪場由 resort frontmatter 的 homeRegionExample boolean 控制。
const getRegionExampleNames = (regionResorts: Resort[]) =>
  regionResorts
    .filter((resort) => resort.data.homeRegionExample)
    .sort(sortRegionExamples)
    .slice(0, regionExampleLimit)
    .map((resort) => resort.data.name.zhTw)

const regionStats = regions.map((region) => {
  const regionResorts = resorts
    .filter((resort) => resort.data.region === region.key)
    .sort((a, b) => regionExampleCollator.compare(a.data.name.zhTw, b.data.name.zhTw))

  return {
    ...region,
    tone: toneByRegion[region.key],
    count: regionResorts.length,
    examples: getRegionExampleNames(regionResorts),
  }
})

const siteUrl = Astro.site ?? new URL('https://jp-resorts.rj-tw.com')
const homeUrl = new URL('/', siteUrl).toString()
const websiteStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '日本滑雪場指南',
  url: homeUrl,
  inLanguage: 'zh-Hant-TW',
  description: '給台灣滑雪者使用的日本滑雪場靜態資料與行程規劃入口。',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${new URL('/resorts/', siteUrl).toString()}?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
}
---

<BaseLayout
  title="日本滑雪場指南"
  description="給台灣滑雪者使用的日本滑雪場資料庫，整理日本各地滑雪場、雪場區域、交通位置、官方資訊與行程規劃入口。"
  bodyClass="home-page"
  canonicalPath="/"
  structuredData={websiteStructuredData}
  showHeaderSearch
>
  <main class="site-shell">
    <section class="home-map-navigation" aria-labelledby="page-title">
      <div class="home-hero">
        <div class="home-hero__copy">
          <p class="eyebrow">Japan ski guide</p>
          <h1 id="page-title" class="home-hero__title">日本滑雪場指南</h1>
          <p class="home-hero__lead">
            身為台灣滑雪愛好者，每次規劃滑雪行程要蒐集資料都很辛苦，所以此網站為整理日本各地滑雪場的官方資訊、交通位置與雪場特色。希望能協助每個愛滑雪的你能輕鬆取得滑雪場資訊並安排適合的旅程。
          </p>
          <form
            class="home-hero-search"
            action={withBasePath('/resorts/')}
            method="get"
            data-site-search
            data-resorts-url={withBasePath('/resorts/')}
            role="search"
            aria-label="搜尋雪場"
          >
            <label class="sr-only" for="home-hero-search-input">搜尋雪場、雪場區域或縣別</label>
            <input
              id="home-hero-search-input"
              name="q"
              type="search"
              autocomplete="off"
              placeholder="輸入雪場名稱、雪場區域或縣別搜尋滑雪場"
            />
            <button type="submit" aria-label="送出搜尋">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h12m-5-5 5 5-5 5" />
              </svg>
            </button>
          </form>
          <div class="home-quick-tags" aria-label="依滑雪情境快速找雪場">
            <div class="home-quick-tags__list">
              {homeQuickTags.map((quickTag) => (
                <a
                  class={`home-quick-tag home-quick-tag--${quickTag.tone}`}
                  href={`${withBasePath('/resorts/')}?tag=${quickTag.tag}`}
                  aria-label={`查看${tagLabels[quickTag.tag]}滑雪場`}
                  data-analytics-select="home_quick_tag"
                  data-select-id={quickTag.tag}
                  data-source-area="home_hero"
                >
                  {tagLabels[quickTag.tag]}
                </a>
              ))}
            </div>
          </div>
          <p class="home-hero__stat">收錄 {resortCount} 座滑雪場</p>
        </div>
      </div>

      <div class="home-map-navigation__map" aria-label="日本滑雪分區地圖">
        <JapanRegionMap mode="overview" regions={regionStats} />
        <p class="home-map-navigation__hint">點選地圖分區，直接前往該區滑雪場整理。</p>

        <div class="home-map-hover-cards" aria-hidden="true">
          {regionStats.map((region) => (
            <div class={`home-map-hover-card home-map-hover-card--${region.key} region-strip--${region.tone}`}>
              <span class="home-map-hover-card__name">{region.name.zhTw}</span>
              <span class="home-map-hover-card__meta">
                {region.count} 座
                {region.examples.length > 0 && ` / ${region.examples.join('、')}`}
              </span>
            </div>
          ))}
        </div>
      </div>

      <div class="home-region-guide" aria-labelledby="home-map-heading">
        <div class="home-region-guide__heading">
          <p class="eyebrow">Region map</p>
          <h2 id="home-map-heading">依區域找雪場</h2>
        </div>

        <div class="home-region-guide__list">
          {regionStats.map((region, index) => (
            <a
              class={`region-strip region-strip--${region.tone}`}
              href={withBasePath(`/regions/${region.key}/`)}
              style={`--index: ${index}`}
              data-analytics-select="region"
              data-select-id={region.key}
              data-source-area="home_region_list"
            >
              <span class="region-strip__name">{region.name.zhTw}</span>
              <small class="region-strip__meta">
                <span class="region-strip__count">{region.count} 座</span>
                {region.examples.length > 0 && (
                  <>
                    <span class="region-strip__separator" aria-hidden="true">/</span>
                    <span class="region-strip__examples">{region.examples.join('、')}</span>
                  </>
                )}
              </small>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
