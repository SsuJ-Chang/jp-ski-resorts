---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import JapanRegionMap from '../components/JapanRegionMap.astro'
import { regions } from '../data/regions'
import { publishedSkiAreaKeys, skiAreas } from '../data/skiAreas'
import { filterPublishedResorts } from '../utils/resorts'
import { withBasePath } from '../utils/paths'

const toneByRegion = {
  hokkaido: 'powder',
  tohoku: 'snow',
  'kanto-koshinetsu': 'access',
  hokuriku: 'coast',
  chubu: 'alps',
  'kansai-chugoku': 'weekend',
  kyushu: 'south',
} as const

const resorts = filterPublishedResorts(await getCollection('resorts'))
const resortCount = resorts.length
const regionExampleLimit = 2
const regionExampleCollator = new Intl.Collator('zh-Hant-TW')
const resortById = new Map(resorts.map((resort) => [resort.id, resort]))
type Resort = (typeof resorts)[number]

// 首頁範例雪場優先採用已發布 ski area 的 featuredResorts；不足兩座才用繁中名稱排序補足。
const getRegionExampleNames = (regionKey: (typeof regions)[number]['key'], regionResorts: Resort[]) => {
  const examples: Resort[] = []
  const selectedIds = new Set<string>()

  const addExample = (resort?: Resort) => {
    if (!resort || resort.data.region !== regionKey || selectedIds.has(resort.id)) return
    examples.push(resort)
    selectedIds.add(resort.id)
  }

  publishedSkiAreaKeys.forEach((areaKey) => {
    const area = skiAreas[areaKey]
    if (area.region !== regionKey) return
    area.featuredResorts.forEach((resortId) => addExample(resortById.get(resortId)))
  })

  regionResorts.forEach(addExample)

  return examples.slice(0, regionExampleLimit).map((resort) => resort.data.name.zhTw)
}

const regionStats = regions.map((region) => {
  const regionResorts = resorts
    .filter((resort) => resort.data.region === region.key)
    .sort((a, b) => regionExampleCollator.compare(a.data.name.zhTw, b.data.name.zhTw))

  return {
    ...region,
    tone: toneByRegion[region.key],
    count: regionResorts.length,
    examples: getRegionExampleNames(region.key, regionResorts),
  }
})
---

<BaseLayout title="日本滑雪場指南" bodyClass="home-page" showHeaderSearch>
  <main class="site-shell">
    <section class="home-hero" aria-labelledby="page-title">
      <div class="home-hero__copy">
        <p class="eyebrow">Japan ski guide</p>
        <h1 id="page-title" class="home-hero__title">日本滑雪場指南</h1>
        <p class="home-hero__lead">
          身為台灣滑雪愛好者，每次規劃滑雪行程要蒐集資料都很辛苦，所以此網站為整理日本各地滑雪場的官方資訊、交通位置與雪場特色。希望能協助每個愛滑雪的你能輕鬆取得滑雪場資訊並安排適合的旅程。
        </p>
        <p class="home-hero__stat">收錄 {resortCount} 座滑雪場</p>
      </div>
      <div class="home-region-guide" aria-label="Japan ski region guide">
        <input class="region-view-toggle__input" id="region-view-list" type="radio" name="region-view" checked />
        <input class="region-view-toggle__input" id="region-view-map" type="radio" name="region-view" />

        <div class="region-view-toggle" aria-label="Region view mode">
          <label for="region-view-list">列表</label>
          <label for="region-view-map">地圖</label>
        </div>

        <div class="home-region-guide__list">
          {regionStats.map((region, index) => (
            <a
              class={`region-strip region-strip--${region.tone}`}
              href={withBasePath(`/regions/${region.key}/`)}
              style={`--index: ${index}`}
            >
              <span class="region-strip__name">{region.name.zhTw}</span>
              <small class="region-strip__meta">
                <span class="region-strip__count">{region.count} 座</span>
                {region.examples.length > 0 && (
                  <span class="region-strip__examples">
                    / {region.examples.join('、')}
                  </span>
                )}
              </small>
            </a>
          ))}
        </div>

        <div class="home-region-guide__map" aria-label="日本滑雪分區地圖">
          <JapanRegionMap mode="overview" regions={regionStats} labelledBy="home-map-title" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
