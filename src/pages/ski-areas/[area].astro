---
import BaseLayout from '../../layouts/BaseLayout.astro'
import CollapsibleLinkList from '../../components/CollapsibleLinkList.astro'
import SkiAreaPositionMap from '../../components/SkiAreaPositionMap.astro'
import { tagLabels } from '../../data/tags'
import { sortResortsForListing } from '../../utils/resortOrdering'
import { getPublishedResorts } from '../../utils/resortCatalog'
import { withBasePath } from '../../utils/paths'
import { getPublishedSkiAreas, type SkiArea } from '../../utils/skiAreas'

export async function getStaticPaths() {
  const areas = await getPublishedSkiAreas()

  return areas.map((area) => ({
    params: { area: area.key },
    props: { area },
  }))
}

const { area } = Astro.props as { area: SkiArea }
const publishedResorts = await getPublishedResorts()
const resorts = sortResortsForListing(
  publishedResorts.filter((resort) => resort.data.skiArea === area.key),
)
const resortById = new Map(resorts.map((resort) => [resort.id, resort]))
const featuredResortIds = area.featuredResorts
const featuredResorts = area.featuredResorts
  .map((id) => resortById.get(id))
  .filter((resort): resort is (typeof resorts)[number] => Boolean(resort))
const otherResorts = resorts.filter((resort) => !featuredResortIds.includes(resort.id))
const orderedResorts = [...featuredResorts, ...otherResorts]

const areaTitle = `${area.name.zhTw}雪場列表`
const hasExternalContent =
  (area.externalContent?.blogs?.length ?? 0) > 0 ||
  (area.externalContent?.vlogs?.length ?? 0) > 0 ||
  (area.externalContent?.websites?.length ?? 0) > 0
---

<BaseLayout title={`${area.name.zhTw}｜日本滑雪場指南`} description={area.summary}>
  <main
    class="site-shell page-stack"
    data-analytics-view="ski_area"
    data-ski-area-key={area.key}
    data-ski-area-region={area.region}
    data-ski-area-prefecture={area.prefecture}
  >
    <a class="text-link" href={withBasePath('/ski-areas/')}>返回雪場區域</a>

    <section class="ski-area-hero" aria-labelledby="page-title">
      <div>
        <p class="eyebrow">{area.name.en} / {area.prefecture}</p>
        <h1 id="page-title">{area.name.zhTw}</h1>
        <p>{area.summary}</p>
      </div>
      <dl class="ski-area-facts" aria-label={`${area.name.zhTw}基本資訊`}>
        {area.accessHub && (
          <div>
            <dt>主要進出點</dt>
            <dd>{area.accessHub}</dd>
          </div>
        )}
        <div>
          <dt>收錄雪場</dt>
          <dd>{resorts.length} 座</dd>
        </div>
      </dl>
    </section>

    <section class="ski-area-traits" aria-label={`${area.name.zhTw}特色`}>
      {area.traits.map((trait) => <span>{trait}</span>)}
    </section>

    <section class="info-panel ski-area-map-panel" aria-labelledby="connection-map-title">
      <div class="section-heading-row">
        <h2 id="connection-map-title">{area.name.zhTw}位置關係</h2>
        <p class="ski-area-map-note">位置為整理用近似示意，方便快速理解雪場分布。</p>
      </div>

      <SkiAreaPositionMap areaKey={area.key} resorts={publishedResorts} />
    </section>

    <section class="info-panel detail-panel--wide" aria-labelledby="area-resorts-title">
      <div class="section-heading-row">
        <h2 id="area-resorts-title">{areaTitle}</h2>
        <span class="section-count">{orderedResorts.length} 座</span>
      </div>
      <div class="resort-grid">
        {orderedResorts.map((resort) => (
          <a
            class="resort-card"
            href={withBasePath(`/resorts/${resort.id}/`)}
            data-resort-card
            data-resort-slug={resort.id}
            data-resort-region={resort.data.region}
            data-resort-prefecture={resort.data.prefecture}
            data-source-area="ski_area_detail"
          >
            <div>
              <p class="resort-card__meta">{resort.data.prefecture}</p>
              <h2>{resort.data.name.zhTw}</h2>
              <p>{resort.data.name.en}</p>
            </div>
            <div class="tag-list" aria-label={`${resort.data.name.zhTw} tags`}>
              {resort.data.tags.slice(0, 4).map((tag) => <span>{tagLabels[tag]}</span>)}
            </div>
          </a>
        ))}
      </div>
    </section>

    {hasExternalContent && (
      <section class="info-panel detail-panel detail-panel--wide external-content-panel">
        <h2>外部參考</h2>
        {area.externalContent?.websites && area.externalContent.websites.length > 0 && (
          <CollapsibleLinkList
            title="參考網站"
            items={area.externalContent.websites}
            analyticsResource="reference_site"
          />
        )}
        {area.externalContent?.blogs && area.externalContent.blogs.length > 0 && (
          <CollapsibleLinkList
            title="部落格"
            items={area.externalContent.blogs}
            analyticsResource="blog"
          />
        )}
        {area.externalContent?.vlogs && area.externalContent.vlogs.length > 0 && (
          <CollapsibleLinkList
            title="影片"
            items={area.externalContent.vlogs}
            analyticsResource="vlog"
          />
        )}
      </section>
    )}
  </main>
</BaseLayout>
