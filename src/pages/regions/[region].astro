---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import JapanRegionMap from '../../components/JapanRegionMap.astro'
import PrefectureFilterNav from '../../components/PrefectureFilterNav.astro'
import ResortSearchResults from '../../components/ResortSearchResults.astro'
import { regions } from '../../data/regions'
import { getPrefectureStats } from '../../utils/resortBrowse'
import { sortResortsForListing } from '../../utils/resortOrdering'
import { filterPublishedResorts } from '../../utils/resorts'

export function getStaticPaths() {
  return regions.map((region) => ({
    params: { region: region.key },
    props: { region },
  }))
}

const { region } = Astro.props
const publishedResorts = filterPublishedResorts(await getCollection('resorts'))
const resorts = sortResortsForListing(
  publishedResorts.filter((resort) => resort.data.region === region.key),
)
const prefectureStats = getPrefectureStats(resorts)
const regionNamesByKey = Object.fromEntries(
  regions.map((region) => [region.key, region.name.zhTw]),
)
---

<BaseLayout
  title={`${region.name.zhTw} | 日本滑雪場指南`}
  description={`${region.name.zhTw}滑雪場資料、官方連結與旅行規劃入口。`}
  showHeaderSearch
>
  <main class="site-shell page-stack">
    <section class="region-heading region-heading--with-map" aria-labelledby="page-title">
      <div class="page-heading">
        <p class="eyebrow">{region.name.en}</p>
        <h1 id="page-title">{region.name.zhTw}</h1>
        <p>{region.description}</p>
        <p class="count-line">收錄 {resorts.length} 座滑雪場</p>
      </div>
      <JapanRegionMap mode="region" region={region} labelledBy={`${region.key}-map-title`} />
    </section>

    <PrefectureFilterNav
      stats={prefectureStats}
      basePath={`/regions/${region.key}/`}
    />

    {
      resorts.length > 0 ? (
        <ResortSearchResults
          resorts={resorts}
          regionNamesByKey={regionNamesByKey}
          showRegionMeta={false}
          ariaLabel={`${region.name.zhTw} resorts`}
        />
      ) : (
        <section class="empty-state" aria-label="No resorts">
          <h2>這個分區尚未收錄滑雪場</h2>
          <p>我們會以官方資訊、交通便利性與旅遊規劃需求為基準，整理適合放入本站的滑雪目的地。</p>
        </section>
      )
    }
  </main>
</BaseLayout>
