---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { regions } from '../../data/regions'
import { tagLabels } from '../../data/tags'
import { filterPublishedResorts, sortResortsByEnglishName } from '../../utils/resorts'
import { withBasePath } from '../../utils/paths'

export function getStaticPaths() {
  return regions.map((region) => ({
    params: { region: region.key },
    props: { region },
  }))
}

const { region } = Astro.props
const resorts = sortResortsByEnglishName(
  filterPublishedResorts(await getCollection('resorts')).filter(
    (resort) => resort.data.region === region.key,
  ),
)
---

<BaseLayout
  title={`${region.name.zhTw} | 日本滑雪場指南`}
  description={`${region.name.zhTw}滑雪場資料、官方連結與旅行規劃入口。`}
>
  <main class="site-shell page-stack">
    <a class="text-link" href={withBasePath('/')}>回首頁</a>

    <section class="page-heading" aria-labelledby="page-title">
      <p class="eyebrow">{region.name.en}</p>
      <h1 id="page-title">{region.name.zhTw}</h1>
      <p>{region.description}</p>
      <p class="count-line">目前收錄 {resorts.length} 間滑雪場。</p>
    </section>

    {
      resorts.length > 0 ? (
        <section class="resort-grid" aria-label={`${region.name.zhTw} resorts`}>
          {resorts.map((resort) => (
            <article class="resort-card">
              <div>
                <p class="resort-card__meta">{resort.data.prefecture}</p>
                <h2>
                  <a href={withBasePath(`/resorts/${resort.id}/`)}>
                    {resort.data.name.zhTw}
                  </a>
                </h2>
                <p>{resort.data.name.en}</p>
              </div>
              <div class="tag-list" aria-label={`${resort.data.name.zhTw} tags`}>
                {resort.data.tags.slice(0, 4).map((tag) => (
                  <span>{tagLabels[tag]}</span>
                ))}
              </div>
            </article>
          ))}
        </section>
      ) : (
        <section class="empty-state" aria-label="No resorts">
          <h2>尚未收錄滑雪場</h2>
          <p>這個區域已保留在分類中，後續會依資料品質與官方來源逐步加入內容。</p>
        </section>
      )
    }
  </main>
</BaseLayout>
