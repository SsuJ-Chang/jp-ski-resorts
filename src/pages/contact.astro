---
import BaseLayout from '../layouts/BaseLayout.astro'

type ContactLinkIcon = 'email' | 'github' | 'linkedin' | 'website' | 'facebook' | 'instagram'

const contactLinks: Array<{
  label: string
  href: string
  icon: ContactLinkIcon
}> = [
  {
    label: 'Email',
    href: 'mailto:loch0728@gmail.com',
    icon: 'email',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/SsuJ-Chang',
    icon: 'github',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/anfer-chang/',
    icon: 'linkedin',
  },
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/anfernee.chang1',
    icon: 'facebook',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/crjakaanfer/',
    icon: 'instagram',
  },
  {
    label: '個人網站',
    href: 'https://rj-tw.com/',
    icon: 'website',
  },
]

const contactStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: '聯絡作者｜日本滑雪場指南',
  description: '提供日本滑雪場指南的資料修正、合作與一般聯絡方式。',
  inLanguage: 'zh-Hant-TW',
  url: 'https://jp-resorts.rj-tw.com/contact/',
}
---

<BaseLayout
  title="聯絡作者｜日本滑雪場指南"
  description="提供日本滑雪場指南的資料修正、合作與一般聯絡方式。"
  bodyClass="contact-page"
  canonicalPath="/contact/"
  structuredData={contactStructuredData}
>
  <main class="site-shell page-stack contact-shell">
    <section class="page-heading contact-hero" aria-labelledby="contact-title">
      <p class="eyebrow">Contact</p>
      <h1 id="contact-title">聯絡作者</h1>
      <p>資料修正、內容補充或合作相關事項，可直接從下面的公開聯絡方式聯絡。</p>
    </section>

    <section class="contact-link-list" aria-label="聯絡方式列表">
      {contactLinks.map((link) => (
        <a
          class="contact-link"
          href={link.href}
          aria-label={link.label}
          title={link.label}
          target={link.href.startsWith('mailto:') ? undefined : '_blank'}
          rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
        >
          <span class="sr-only">{link.label}</span>
          <svg class="contact-link__icon" viewBox="0 0 24 24" aria-hidden="true">
            {link.icon === 'email' && (
              <>
                <rect x="3.5" y="6" width="17" height="12" rx="2.5" />
                <path d="m5.5 8 6.5 5 6.5-5" />
              </>
            )}
            {link.icon === 'github' && (
              <path
                data-filled="true"
                d="M12 3.8a8.2 8.2 0 0 0-2.6 16c.4.1.5-.2.5-.4v-1.7c-2.1.5-2.6-.9-2.6-.9-.3-.8-.9-1-1-1-.8-.5.1-.5.1-.5.8.1 1.3.8 1.4.9.8 1.2 2 .9 2.5.7.1-.5.3-.9.6-1.1-1.7-.2-3.5-.9-3.5-3.8 0-.8.3-1.5.8-2-.1-.2-.4-1 .1-2.1 0 0 .7-.2 2.2.8a7.2 7.2 0 0 1 4 0c1.5-1 2.2-.8 2.2-.8.5 1.1.2 1.9.1 2.1.5.5.8 1.2.8 2 0 2.9-1.8 3.6-3.5 3.8.3.3.6.8.6 1.5v2.3c0 .2.1.5.5.4A8.2 8.2 0 0 0 12 3.8Z"
              />
            )}
            {link.icon === 'linkedin' && (
              <>
                <rect x="4.5" y="4.5" width="15" height="15" rx="2.5" />
                <path d="M8.2 10.2v5.6" />
                <path d="M8.2 8.2h.01" />
                <path d="M12.1 15.8v-3.2c0-1.3.7-2.1 1.8-2.1 1 0 1.6.7 1.6 1.9v3.4" />
                <path d="M12.1 10.2v5.6" />
              </>
            )}
            {link.icon === 'facebook' && (
              <path
                data-filled="true"
                d="M13.8 21v-7h2.5l.5-3.4h-3V8.5c0-.9.5-1.4 1.5-1.4h1.6V4.1c-.8-.1-1.7-.1-2.5-.1-2.7 0-4.5 1.6-4.5 4.3v2.3H7.5V14h2.4v7h3.9Z"
              />
            )}
            {link.icon === 'instagram' && (
              <>
                <rect x="5" y="5" width="14" height="14" rx="4" />
                <circle cx="12" cy="12" r="3.2" />
                <path d="M16.6 7.4h.01" />
              </>
            )}
            {link.icon === 'website' && (
              <>
                <circle cx="12" cy="12" r="8.5" />
                <path d="M3.5 12h17" />
                <path d="M12 3.5c2.3 2.3 3.5 5.2 3.5 8.5s-1.2 6.2-3.5 8.5c-2.3-2.3-3.5-5.2-3.5-8.5s1.2-6.2 3.5-8.5Z" />
              </>
            )}
          </svg>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
