---
import type { ResortEntry } from '../utils/resorts'
import { tagLabels } from '../data/tags'
import { withBasePath } from '../utils/paths'
import { getResortPrefectureKey } from '../utils/resortBrowse'

type Props = {
  resorts: ResortEntry[]
  regionNamesByKey?: Record<string, string>
  showRegionMeta?: boolean
  ariaLabel?: string
  sourceArea?: string
}

const {
  resorts,
  regionNamesByKey = {},
  showRegionMeta = true,
  ariaLabel = 'Resorts',
  sourceArea = 'resort_listing',
} = Astro.props
---

<div class="resort-list-summary" aria-live="polite">
  <span data-resort-result-count>{resorts.length} 座雪場</span>
</div>

<section class="resort-grid" aria-label={ariaLabel} data-resort-results data-source-area={sourceArea}>
  {resorts.map((resort) => {
    const prefectureKey = getResortPrefectureKey(resort) ?? ''
    const regionName = regionNamesByKey[resort.data.region] ?? resort.data.region
    const metaParts = showRegionMeta ? [regionName, resort.data.prefecture] : [resort.data.prefecture]
    const searchableName = [
      resort.data.name.zhTw,
      resort.data.name.ja,
      resort.data.name.en,
    ].filter(Boolean).join(' ')

    return (
      <a
        class="resort-card"
        href={withBasePath(`/resorts/${resort.id}/`)}
        data-resort-card
        data-search-text={searchableName}
        data-resort-slug={resort.id}
        data-resort-region={resort.data.region}
        data-resort-prefecture={resort.data.prefecture}
        data-source-area={sourceArea}
        data-prefecture-key={prefectureKey}
        data-tags={resort.data.tags.join(' ')}
      >
        <div>
          <p class="resort-card__meta">
            {metaParts.join(' / ')}
          </p>
          <h2>{resort.data.name.zhTw}</h2>
          <p>{resort.data.name.en}</p>
        </div>
        <div class="tag-list" aria-label={`${resort.data.name.zhTw} tags`}>
          {resort.data.tags.slice(0, 4).map((tag) => (
            <span>{tagLabels[tag]}</span>
          ))}
        </div>
      </a>
    )
  })}
</section>

<script>
  import '../scripts/resortSearchResults.ts'
</script>
