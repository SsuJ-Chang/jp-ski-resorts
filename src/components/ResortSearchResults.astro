---
import type { ResortEntry } from '../utils/resorts'
import { tagLabels } from '../data/tags'
import { regions } from '../data/regions'
import { withBasePath } from '../utils/paths'
import { getResortPrefecture } from '../utils/resortBrowse'
import { getPublishedSkiAreaMap } from '../utils/skiAreas'

type Props = {
  resorts: ResortEntry[]
  regionNamesByKey?: Record<string, string>
  showRegionMeta?: boolean
  ariaLabel?: string
  sourceArea?: string
}

const {
  resorts,
  regionNamesByKey = {},
  showRegionMeta = true,
  ariaLabel = 'Resorts',
  sourceArea = 'resort_listing',
} = Astro.props

const skiAreaMap = await getPublishedSkiAreaMap()
const regionByKey = new Map(regions.map((region) => [region.key, region] as const))

const toSearchText = (parts: Array<string | undefined>) =>
  parts.filter(Boolean).join(' ')
---

<div class="resort-list-summary" aria-live="polite">
  <span data-resort-result-count>{resorts.length} 座雪場</span>
</div>

<section class="resort-grid" aria-label={ariaLabel} data-resort-results data-source-area={sourceArea}>
  {resorts.map((resort) => {
    const prefecture = getResortPrefecture(resort)
    const prefectureKey = prefecture?.key ?? ''
    const region = regionByKey.get(resort.data.region)
    const skiArea = resort.data.skiArea ? skiAreaMap.get(resort.data.skiArea) : undefined
    const regionName = regionNamesByKey[resort.data.region] ?? resort.data.region
    const metaParts = showRegionMeta ? [regionName, resort.data.prefecture] : [resort.data.prefecture]

    const searchableName = toSearchText([
      resort.data.name.zhTw,
      resort.data.name.ja,
      resort.data.name.en,
    ])
    const searchableSkiArea = toSearchText([
      skiArea?.name.zhTw,
      skiArea?.name.ja,
      skiArea?.name.en,
      skiArea?.key,
    ])
    const searchablePrefecture = toSearchText([
      prefecture?.name.zhTw,
      prefecture?.name.ja,
      prefecture?.name.en,
      prefecture?.key,
      resort.data.prefecture,
    ])
    const searchableRegion = toSearchText([
      region?.name.zhTw,
      region?.name.en,
      region?.key,
      resort.data.region,
      regionName,
    ])
    const searchableAll = toSearchText([
      searchableName,
      searchableSkiArea,
      searchablePrefecture,
      searchableRegion,
    ])

    return (
      <a
        class="resort-card"
        href={withBasePath(`/resorts/${resort.id}/`)}
        data-resort-card
        data-search-text={searchableAll}
        data-search-name={searchableName}
        data-search-ski-area={searchableSkiArea}
        data-search-prefecture={searchablePrefecture}
        data-search-region={searchableRegion}
        data-resort-slug={resort.id}
        data-resort-region={resort.data.region}
        data-resort-prefecture={resort.data.prefecture}
        data-source-area={sourceArea}
        data-prefecture-key={prefectureKey}
        data-tags={resort.data.tags.join(' ')}
      >
        <div>
          <p class="resort-card__meta">
            {metaParts.join(' / ')}
          </p>
          <h2>{resort.data.name.zhTw}</h2>
          <p>{resort.data.name.en}</p>
        </div>
        <div class="tag-list" aria-label={`${resort.data.name.zhTw} tags`}>
          {resort.data.tags.slice(0, 4).map((tag) => (
            <span>{tagLabels[tag]}</span>
          ))}
        </div>
      </a>
    )
  })}
</section>

<script>
  import '../scripts/resortSearchResults.ts'
</script>
