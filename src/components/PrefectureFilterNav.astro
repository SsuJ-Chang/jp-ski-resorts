---
import type { PrefectureStat } from '../utils/resortBrowse'
import { withBasePath } from '../utils/paths'

type Props = {
  stats: PrefectureStat[]
  basePath: string
  showIndexLink?: boolean
}

const {
  stats,
  basePath,
  showIndexLink = true,
} = Astro.props

const normalizedBasePath = basePath.endsWith('/') ? basePath : `${basePath}/`
const allHref = withBasePath(normalizedBasePath)
const showPrefectureMenu = stats.length > 1
---

<section class="listing-toolbar" aria-label="列表篩選" data-prefecture-filter data-filter-base-path={allHref}>
  {showPrefectureMenu && (
    <details class="filter-menu" data-filter-menu>
      <summary class="filter-menu__button">
        <span data-prefecture-filter-label>縣別：全部</span>
        <span class="filter-menu__chevron" aria-hidden="true"></span>
      </summary>

      <form class="filter-menu__panel" method="get" action={allHref} data-prefecture-filter-form>
        <div class="filter-menu__header">
          <strong>選擇縣別</strong>
        </div>

        <div class="filter-option-list">
          {stats.map((prefecture) => (
            <label class="filter-option">
              <input
                type="checkbox"
                name="prefecture"
                value={prefecture.key}
                data-prefecture-option
                data-prefecture-name={prefecture.name.zhTw}
              />
              <span>{prefecture.name.zhTw} ({prefecture.count})</span>
            </label>
          ))}
        </div>

        <div class="filter-menu__footer">
          <button type="button" class="button-link" data-prefecture-clear>清除</button>
          <button type="submit" class="button-primary">套用</button>
        </div>
      </form>
    </details>
  )}

  {showIndexLink && <a class="listing-toolbar__link" href={withBasePath('/prefectures/')}>縣別索引</a>}
</section>

<script>
  const filterBlocks = document.querySelectorAll<HTMLElement>('[data-prefecture-filter]')
  const currentParams = new URLSearchParams(window.location.search)
  const currentSearchQuery = currentParams.get('q')
  const selectedPrefectures = new Set(currentParams.getAll('prefecture').filter(Boolean))

  for (const block of filterBlocks) {
    const basePath = block.dataset.filterBasePath ?? window.location.pathname
    const menu = block.querySelector<HTMLDetailsElement>('[data-filter-menu]')
    const form = block.querySelector<HTMLFormElement>('[data-prefecture-filter-form]')
    const label = block.querySelector<HTMLElement>('[data-prefecture-filter-label]')
    const clearButton = block.querySelector<HTMLButtonElement>('[data-prefecture-clear]')
    const options = Array.from(block.querySelectorAll<HTMLInputElement>('[data-prefecture-option]'))

    const updateLabel = () => {
      const selectedOptions = options.filter((option) => option.checked)

      if (selectedOptions.length === 0 || selectedOptions.length === options.length) {
        if (label) label.textContent = '縣別：全部'
        return
      }

      const selectedNames = selectedOptions.map((option) => option.dataset.prefectureName ?? option.value)
      const visibleNames = selectedNames.slice(0, 2).join('、')
      const hiddenCount = selectedNames.length - 2
      const suffix = hiddenCount > 0 ? ` +${hiddenCount}` : ''

      if (label) label.textContent = `縣別：${visibleNames}${suffix}`
    }

    for (const option of options) {
      option.checked = selectedPrefectures.has(option.value)
      option.addEventListener('change', updateLabel)
    }

    clearButton?.addEventListener('click', () => {
      for (const option of options) option.checked = false
      updateLabel()
    })

    form?.addEventListener('submit', (event) => {
      event.preventDefault()

      const nextParams = new URLSearchParams()
      if (currentSearchQuery) nextParams.set('q', currentSearchQuery)

      const selectedOptions = options.filter((option) => option.checked)

      if (selectedOptions.length !== options.length) {
        for (const option of selectedOptions) {
          nextParams.append('prefecture', option.value)
        }
      }

      const queryString = nextParams.toString()
      window.location.assign(queryString ? `${basePath}?${queryString}` : basePath)
    })

    updateLabel()

    document.addEventListener('click', (event) => {
      if (!menu?.open) return
      if (event.target instanceof Node && block.contains(event.target)) return
      menu.open = false
    })
  }
</script>
