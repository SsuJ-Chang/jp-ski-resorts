---
import type { RegionKey } from '../data/regions'
import { mapRegionShapes } from '../data/mapRegions'
import { withBasePath } from '../utils/paths'

type MapRegion = {
  key: RegionKey
  name: {
    zhTw: string
  }
  tone: string
  count: number
}

type RegionLike = {
  key: RegionKey
  name: {
    zhTw: string
  }
}

type Props = {
  mode?: 'overview' | 'region'
  regions?: MapRegion[]
  region?: RegionLike
}

const { mode = 'overview', regions = [], region } = Astro.props

const toneByRegion = {
  hokkaido: 'powder',
  tohoku: 'snow',
  'kanto-koshinetsu': 'access',
  hokuriku: 'coast',
  chubu: 'alps',
  'kansai-chugoku': 'weekend',
  kyushu: 'south',
} as const

const mapRegionClass = {
  hokkaido: 'map-region--hokkaido',
  tohoku: 'map-region--tohoku',
  'kanto-koshinetsu': 'map-region--kanto',
  hokuriku: 'map-region--hokuriku',
  chubu: 'map-region--chubu',
  'kansai-chugoku': 'map-region--kansai',
  kyushu: 'map-region--kyushu',
} as const

const overviewRegions = mode === 'overview' ? regions : []
const regionShape = region ? mapRegionShapes[region.key] : null
const regionTone = region ? toneByRegion[region.key] : null
const viewBox = mode === 'region' && regionShape ? regionShape.viewBox : '0 0 800 720'
const ariaLabel = mode === 'region' && region ? `${region.name.zhTw}分區地圖` : '日本滑雪分區地圖'
---

<svg
  class:list={[
    'japan-region-map',
    mode === 'overview' ? 'japan-region-map--overview' : 'japan-region-map--region',
  ]}
  viewBox={viewBox}
  role="img"
  aria-label={ariaLabel}
>
  {
    mode === 'overview' ? (
      <>
        {overviewRegions.map((item) => (
          <a
            class:list={[
              'map-region',
              mapRegionClass[item.key],
              `region-strip--${item.tone}`,
            ]}
            href={withBasePath(`/regions/${item.key}/`)}
            aria-label={`${item.name.zhTw}，收錄 ${item.count} 座滑雪場`}
            data-analytics-select="region"
            data-select-id={item.key}
            data-source-area="home_region_map"
          >
            <path d={mapRegionShapes[item.key].path} />
          </a>
        ))}
        <g class="map-region-labels" aria-hidden="true">
          {overviewRegions.map((item) => (
            <text x={mapRegionShapes[item.key].labelX} y={mapRegionShapes[item.key].labelY}>
              <tspan>{item.name.zhTw}</tspan>
              <tspan x={mapRegionShapes[item.key].labelX} dy="18">
                {item.count} 座
              </tspan>
            </text>
          ))}
        </g>
      </>
    ) : region && regionShape ? (
      <g
        class:list={[
          'map-region',
          mapRegionClass[region.key],
          `region-strip--${regionTone}`,
          'map-region--static',
          'map-region--active',
        ]}
        aria-label={`${region.name.zhTw} 的獨立輪廓`}
      >
        <path d={regionShape.path} />
      </g>
    ) : null
  }
</svg>
