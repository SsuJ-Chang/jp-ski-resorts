---
import type { RegionKey } from '../data/regions'
import { withBasePath } from '../utils/paths'

type MapRegion = {
  key: RegionKey
  name: {
    zhTw: string
  }
  tone: string
  count: number
}

type RegionLike = {
  key: RegionKey
  name: {
    zhTw: string
  }
}

type Props = {
  mode?: 'overview' | 'region'
  regions?: MapRegion[]
  region?: RegionLike
  labelledBy?: string
}

const { mode = 'overview', regions = [], region, labelledBy = 'map-title' } = Astro.props

const toneByRegion = {
  hokkaido: 'powder',
  tohoku: 'snow',
  'kanto-koshinetsu': 'access',
  hokuriku: 'coast',
  chubu: 'alps',
  'kansai-chugoku': 'weekend',
  kyushu: 'south',
} as const

const mapRegionClass = {
  hokkaido: 'map-region--hokkaido',
  tohoku: 'map-region--tohoku',
  'kanto-koshinetsu': 'map-region--kanto',
  hokuriku: 'map-region--hokuriku',
  chubu: 'map-region--chubu',
  'kansai-chugoku': 'map-region--kansai',
  kyushu: 'map-region--kyushu',
} as const

const regionShapes = {
  hokkaido: {
    path:
      'M335 42 C374 24 427 29 460 56 C478 71 481 97 465 116 C450 134 423 139 399 135 C373 131 347 139 326 129 C300 117 290 87 302 65 C310 52 323 47 335 42 Z',
    labelX: 389,
    labelY: 92,
  },
  tohoku: {
    path:
      'M326 146 C354 134 392 139 412 165 C427 186 420 210 428 232 C437 257 455 275 446 303 C436 334 399 345 373 330 C347 315 336 291 319 270 C302 249 291 225 299 200 C305 180 308 156 326 146 Z',
    labelX: 377,
    labelY: 236,
  },
  'kanto-koshinetsu': {
    path:
      'M274 274 C301 258 339 261 360 289 C376 310 403 324 396 350 C388 379 349 389 320 378 C296 369 268 383 251 358 C234 333 242 291 274 274 Z',
    labelX: 322,
    labelY: 334,
  },
  hokuriku: {
    path:
      'M219 289 C240 271 270 266 294 279 C284 301 272 324 256 344 C230 339 204 335 186 318 C193 305 205 296 219 289 Z',
    labelX: 239,
    labelY: 316,
  },
  chubu: {
    path:
      'M214 339 C241 328 276 339 297 361 C315 381 303 407 281 424 C255 444 223 431 199 416 C175 400 170 369 191 351 C197 345 205 342 214 339 Z',
    labelX: 244,
    labelY: 390,
  },
  'kansai-chugoku': {
    path:
      'M63 393 C99 367 147 355 189 371 C209 379 214 404 203 423 C186 452 141 461 109 481 C79 499 40 492 25 465 C13 440 35 411 63 393 Z',
    labelX: 125,
    labelY: 428,
  },
  kyushu: {
    path:
      'M61 505 C92 492 127 507 140 539 C152 570 136 606 107 628 C78 650 40 637 23 607 C8 578 20 533 61 505 Z',
    labelX: 81,
    labelY: 571,
  },
} as const

const overviewRegions = mode === 'overview' ? regions : []
const regionShape = region ? regionShapes[region.key] : null
const regionTone = region ? toneByRegion[region.key] : null
---

<svg
  class:list={[
    'japan-region-map',
    mode === 'overview' ? 'japan-region-map--overview' : 'japan-region-map--region',
  ]}
  viewBox="0 0 500 670"
  role="img"
  aria-labelledby={labelledBy}
>
  <title id={labelledBy}>日本滑雪分區地圖</title>
  {
    mode === 'overview' ? (
      overviewRegions.map((item) => (
        <a
          class:list={[
            'map-region',
            mapRegionClass[item.key],
            `region-strip--${item.tone}`,
          ]}
          href={withBasePath(`/regions/${item.key}/`)}
          aria-label={`${item.name.zhTw}，收錄 ${item.count} 座滑雪場`}
        >
          <path d={regionShapes[item.key].path} />
          <text x={regionShapes[item.key].labelX} y={regionShapes[item.key].labelY}>
            <tspan>{item.name.zhTw}</tspan>
            <tspan x={regionShapes[item.key].labelX} dy="18">
              {item.count} 座
            </tspan>
          </text>
        </a>
      ))
    ) : region && regionShape ? (
      <g
        class:list={[
          'map-region',
          mapRegionClass[region.key],
          `region-strip--${regionTone}`,
          'map-region--static',
          'map-region--active',
        ]}
        aria-label={`${region.name.zhTw} 的獨立輪廓`}
      >
        <path d={regionShape.path} />
      </g>
    ) : null
  }
</svg>
